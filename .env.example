# AgricultureID environment configuration (all optional in Phase 1).
# Copy to .env.local to override. The app builds and runs without any of these.

# Canonical site origin used for absolute URLs (canonical tags, sitemap, OG).
# Defaults to https://agricultureid.com when unset.
# NEXT_PUBLIC_SITE_URL=https://agricultureid.com

# WebmasterID Analytics integration point (INERT unless BOTH are set).
# Do not enable without an authorized site id and script URL.
# NEXT_PUBLIC_WEBMASTERID_SITE_ID=
# NEXT_PUBLIC_WEBMASTERID_SRC=
